# HR RECRUITMENT AGENT - CONFIGURATION FILE
# Copy this file to .env and fill in your actual credentials
# KEEP THIS FILE SECRET - DO NOT SHARE!

# ===== GMAIL CONFIGURATION =====
# Your Gmail address
GMAIL_ADDRESS=your_email@gmail.com

# Your Gmail App Password (16 characters)
# Get this from: https://myaccount.google.com/apppasswords
# Make sure 2-Step Verification is enabled first!
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ===== GOOGLE CALENDAR CONFIGURATION =====
# Path to your Google credentials JSON file
# Download from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json

# Your calendar ID (usually "primary")
GOOGLE_CALENDAR_ID=primary

# ===== OPENAI CONFIGURATION (OPTIONAL - FOR FUTURE FEATURES) =====
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_your_key_here

# ===== DATABASE CONFIGURATION =====
# Where to store candidate data
DATABASE_FILE=candidates.db

# Where resumes are stored
RESUME_FOLDER=resumes

# Path to job description file
JOB_DESCRIPTION_FILE=resumes/job_description.txt

# ===== INTERVIEW SETTINGS =====
# Duration of each interview in minutes
INTERVIEW_DURATION_MINUTES=30

# Timezone for scheduling
# Examples: Asia/Kolkata, US/Eastern, Europe/London
INTERVIEW_TIMEZONE=Asia/Kolkata

# ===== SCORING THRESHOLDS =====
# Minimum score to ACCEPT candidate (0.0 to 1.0)
# Example: 0.70 = 70%
SCORE_ACCEPT_THRESHOLD=0.70

# Minimum score to HOLD candidate for manual review (0.0 to 1.0)
# Below this = REJECT
SCORE_HOLD_THRESHOLD=0.50

# ===== JOB SETTINGS =====
# Position title
JOB_TITLE=Software Developer

# Company name
COMPANY_NAME=Your Company Name
